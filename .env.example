JUNGLEGRID_API_KEY=
JUNGLEGRID_API_BASE=https://api.junglegrid.dev
JUNGLEGRID_MODE=junglegrid-qwen
JUNGLEGRID_DEFAULT_WORKLOAD_TYPE=inference
JUNGLEGRID_DEFAULT_IMAGE=junglegrid/outreach-qwen-worker:latest
JUNGLEGRID_OPTIMIZE_FOR=cost
JUNGLEGRID_REGISTRY_CREDENTIAL_ID=
JUNGLEGRID_POLL_INTERVAL_MS=3000
JUNGLEGRID_JOB_TIMEOUT_MS=1800000

OLLAMA_MODEL=qwen2.5:3b
OLLAMA_HOST=http://127.0.0.1:11434
USE_LOCAL_LLM=true
LLM_FALLBACK_MODE=template

GITHUB_TOKEN=

ZEPTOMAIL_API_KEY=
ZEPTOMAIL_API_BASE=
ZEPTOMAIL_FROM_EMAIL=bbg@junglegrid.dev
ZEPTOMAIL_FROM_NAME=Benedict from Jungle Grid
ZEPTOMAIL_REPLY_TO=bbg@junglegrid.dev
ZEPTOMAIL_TEST_RECIPIENT=
# ZeptoMail is documented for transactional email. Keep disabled unless your
# use case is compliant and you intentionally enable manual approved sends.
EMAIL_SEND_MODE=disabled

DATABASE_URL=./data/outreach-agent.sqlite
DAILY_TARGET=17
JUNGLEGRID_SITE=https://junglegrid.dev
FIT_SCORE_THRESHOLD=70
MAX_DRAFTS_PER_RUN=17
MAX_DRAFTS_PER_DOMAIN=2
DRY_RUN=true
LOG_LEVEL=info
